@model List<HotelTool.Web.Models.Hotel>

<table class="hotel-table">
    <thead>
        <tr>
            <th>#</th>
            <th>Name</th>
            <th>Address</th>
            <th>Stars</th>
            <th>Contact</th>
            <th>Phone</th>
            <th>URL</th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i < Model.Count; i++)
        {
            var hotel = Model[i];
            <tr>
                <td style="color: var(--text-muted);">@(i + 1)</td>
                <td><strong>@hotel.Name</strong></td>
                <td style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@hotel.Address">
                    @hotel.Address
                </td>
                <td>
                    <span class="stars">
                        @for (int s = 0; s < hotel.Stars; s++)
                        {
                            <text>★</text>
                        }
                        @for (int s = hotel.Stars; s < 5; s++)
                        {
                            <text>☆</text>
                        }
                    </span>
                </td>
                <td>@hotel.Contact</td>
                <td>@hotel.Phone</td>
                <td>
                    <a href="@hotel.Uri" target="_blank" class="url-link" title="@hotel.Uri">
                        @(hotel.Uri.Length > 35 ? hotel.Uri[..35] + "..." : hotel.Uri)
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
